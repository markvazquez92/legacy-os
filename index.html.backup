<!-- OPENING — full viewport reveal -->
<section class="opening">
  <div class="ship-wrap">
    <div class="ship-glow"></div>
    <img src="logo.png" alt="My Legacy Continues" class="ship-img">
    <span class="opening-wordmark">My Legacy Continues</span>
    <h1 class="opening-title">
      Every life deserves<br>
      <em>a permanent home.</em>
    </h1>
    <p class="opening-sub">
      Not a post that disappears. A real record that grows over time and never goes away — for your family, your business, your community.
    </p>
    <div class="opening-ctas">
      <a href="#pillars" class="btn-shine btn-primary-gold">See the Platform</a>
      <a href="#products" class="btn-shine btn-ghost">View Products</a>
    </div>
  </div>
