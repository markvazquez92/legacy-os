        <span class="stat-label">Earliest confirmed family record</span>
      </div>
      <div class="origin-stat">
        <span class="stat-num">4</span>
        <span class="stat-label">Pillars of the platform</span>
      </div>
      <div class="origin-stat">
        <span class="stat-num">$0</span>
        <span class="stat-label">Subscriptions required</span>
      </div>
      <div class="origin-stat">
        <span class="stat-num">Forever</span>
        <span class="stat-label">How long your story stays online</span>
      </div>
    </div>
